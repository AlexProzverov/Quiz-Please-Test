  tutorialText: {fileID: 1324231456}
  sellButton: {fileID: 1252294734}
  tutorialFirstHitText: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u043D\u0430
    \u043A\u0430\u043C\u0435\u043D\u044C,\n\u0447\u0442\u043E\u0431\u044B \u0434\u043E\u0431\u044B\u0432\u0430\u0442\u044C
    \u0440\u0443\u0434\u0443!"
  tutorialSellText: "\u0423 \u0432\u0430\u0441 10 \u0440\u0443\u0434\u044B!\n\u041D\u0430\u0436\u043C\u0438\u0442\u0435
    \u043D\u0430 \u0441\u0447\u0451\u0442\u0447\u0438\u043A \u0440\u0443\u0434\u044B,\n\u0447\u0442\u043E\u0431\u044B
    \u043F\u0440\u043E\u0434\u0430\u0442\u044C \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0437\u043E\u043B\u043E\u0442\u043E!"
  tutorialUpgradeText: "\u0422\u0435\u043F\u0435\u0440\u044C \u043D\u0430\u0436\u043C\u0438\u0442\u0435
    \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443 \u043F\u0440\u043E\u043A\u0430\u0447\u043A\u0438\n\u0447\u0442\u043E\u0431\u044B
    \u0443\u043B\u0443\u0447\u0448\u0438\u0442\u044C \u043A\u0438\u0440\u043A\u0443!"
  tutorialCollectMoreText: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E! \u0414\u043E\u0431\u044B\u0432\u0430\u0439\u0442\u0435
    \u0440\u0443\u0434\u0443,\n\u043F\u043E\u043A\u0430 \u043D\u0435 \u043D\u0430\u043A\u043E\u043F\u0438\u0442\u0441\u044F
    10 \u0448\u0442\u0443\u043A."
  tutorialWaitForGoldText: "\u0422\u0435\u043F\u0435\u0440\u044C \u043D\u0430\u043A\u043E\u043F\u0438\u0442\u0435
